{
  "name": "@ibm-skills-network/olx-cli",
  "description": "A command line tool for Open Learning XML",
  "version": "0.1.19",
  "author": "Skills Network <mroudnitski@ibm.com>",
  "bin": {
    "olx-cli": "./bin/run"
  },
  "type": "commonjs",
  "bugs": "https://github.com/ibm-skills-network/olx-cli/issues",
  "dependencies": {
    "@ibm-skills-network/xml-js": "^1.6.12",
    "@oclif/command": "^1",
    "@oclif/config": "^1",
    "@oclif/plugin-help": "^6.0.0",
    "cheerio": "^1.0.0-rc.12",
    "file-type": "^21.0.0",
    "glob": "^7.2.3",
    "got": "^11.8.3",
    "mime-types": "^2.1.31",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@oclif/dev-cli": "^1",
    "@types/node": "^20",
    "globby": "^10",
    "prettier": "^2.2.1",
    "typescript": "^5.3"
  },
  "resolutions": {
    "lodash": "^4.18.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "/bin",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json",
    "/src"
  ],
  "homepage": "https://github.com/ibm-skills-network/olx-cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "src/index.js",
  "oclif": {
    "commands": "./src/commands",
    "bin": "olx-cli",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "repository": "ibm-skills-network/olx-cli",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "oclif-dev manifest && rm -f oclif.manifest.json",
    "format": "prettier --write \"src/**/*.js\" \"*.md\" \"package.json\" \".github/**/*.yml\"",
    "lint": "prettier --check \"src/**/*.js\" \"*.md\" \"package.json\" \".github/**/*.yml\"",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "oclif-dev manifest",
    "test": "node --test --experimental-test-coverage test/**/*.test.js",
    "version": "oclif-dev readme && prettier --write README.md && git add README.md"
  }
}
